# Terraform-specific ignores

# Local .terraform directories
**/.terraform/*

# .tfstate files
# These files store the state of your managed infrastructure.
# They may contain sensitive data.
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# passwords, private keys, and other secrets.
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local testing or development.
override.tf
override.tf.json
*_override.tf
*_override.tf.json